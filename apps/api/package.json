{
  "name": "@atlas/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps --env-file-if-exists=../../.env dist/main.js",
    "dev": "concurrently -n tsc,node -c blue,green \"tsc -p tsconfig.json --watch --preserveWatchOutput\" \"node --enable-source-maps --env-file-if-exists=../../.env --watch dist/main.js\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atlas/ai": "workspace:*",
    "@atlas/connectors": "workspace:*",
    "@atlas/db": "workspace:*",
    "@atlas/shared": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "cookie-parser": "^1.4.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "concurrently": "^9.0.1",
    "typescript": "^5.6.2"
  }
}
