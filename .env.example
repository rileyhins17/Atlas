# ─────────────────────────────────────────────────────────────
# Atlas environment. Copy to `.env` and fill in. NEVER commit .env
# ─────────────────────────────────────────────────────────────

# --- Postgres (used by docker-compose to init the DB) ---
POSTGRES_USER=atlas
POSTGRES_PASSWORD=change-me-in-real-deploy
POSTGRES_DB=atlas

# --- Database connection string (used by the API / Prisma) ---
# Inside docker-compose the host is the service name `db`.
# For running the API on your host machine against docker Postgres, use localhost.
DATABASE_URL=postgresql://atlas:change-me-in-real-deploy@db:5432/atlas?schema=public

# --- Auth / session ---
# Long random string. Generate: openssl rand -hex 32
SESSION_SECRET=generate-a-64-char-random-hex-string

# --- App-level encryption key for stored API credentials (AES-256) ---
# MUST be 64 hex chars (32 bytes). Generate: openssl rand -hex 32
# If this is lost, all stored connector credentials become unrecoverable.
APP_ENCRYPTION_KEY=generate-a-64-char-random-hex-string

# --- AI provider (DeepSeek direct) ---
# No API key here: it's saved per-user via POST /ai/connect/deepseek and stored
# AES-GCM encrypted in the credentials table. Get one at https://platform.deepseek.com
# Use a CONCRETE model id, never an alias like "deepseek-chat" — the API resolves
# aliases server-side and echoes the real id back, which is what the cost guard
# prices against; an unknown id silently bills at a fallback rate. See docs/GOTCHAS.md.
AI_MODEL=deepseek-v4-flash
# Hard safety cap on tokens spent per day (cost guard). 0 = AI disabled.
AI_DAILY_TOKEN_CAP=200000

# Embeddings run on a local in-process model — no key, no per-call cost.
# See docs/adr/0003-ai-providers.md.

# --- Google Calendar connector (OAuth) ---
# App-level OAuth client from Google Cloud Console (Calendar API enabled).
# Per-user access/refresh TOKENS are stored encrypted in the credentials table, not here.
# Leave blank to disable the Google connector.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI on the OAuth client.
GOOGLE_REDIRECT_URI=http://localhost:4000/connectors/google/callback

# --- Web app: where the browser reaches the API ---
# Local dev: http://localhost:4000 . Production: https://atlas.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Ports (local dev) ---
API_PORT=4000
WEB_PORT=3000

# --- Deployment domain (Caddy auto-HTTPS). Local: leave as localhost ---
ATLAS_DOMAIN=localhost
